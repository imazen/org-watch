# Copy to .env, fill in, then run ./setup.sh (you must be `gh auth`'d as an imazen admin).
# .env is gitignored — never commit real secrets.

# Classic GitHub PAT used by the workflow to read every repo's events (incl. private)
# and to read/write the WATCH_STATE variable. Scopes: repo + read:org
ORG_READ_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Resend API key (https://resend.com → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Where alerts go.
ALERT_TO=river.lilith@gmail.com

# From address. onboarding@resend.dev works out-of-the-box ONLY to the email you
# signed up to Resend with. For anything else, verify a domain in Resend and use
# e.g. "imazen org-watch <watch@imazen.org>".
ALERT_FROM=imazen org-watch <onboarding@resend.dev>

# ---- optional overrides (defaults are fine) ----
# WATCH_SELF_LOGINS=lilith                 # comma-sep logins treated as "the owner"
# WATCH_BOT_DENYLIST=some-extra-bot        # extra bots to ignore (on top of built-ins)
# WATCH_STATE_REPO=imazen/org-watch        # repo holding the WATCH_STATE variable

# Copy to .env, fill in, then run ./setup.sh (you must be `gh auth`'d as an imazen admin).
# .env is gitignored — never commit real secrets.

# GitHub token used by the workflow to read every repo's events (incl. private)
# and to read/write the WATCH_STATE variable.
#  - Classic token (easiest): https://github.com/settings/tokens/new  → scopes: repo + read:org
#  - Fine-grained alt: https://github.com/settings/personal-access-tokens/new
#      Resource owner = imazen, All repositories; Repository permissions:
#      Metadata=Read, Contents=Read, Issues=Read, Pull requests=Read, Variables=Read and write
ORG_READ_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ===== Sender: pick ONE. The Apprise notifier (below) is preferred — no email account needed. =====

# A notifier URL handled by Apprise (https://github.com/caronc/apprise/wiki). Examples:
#   Telegram:  tgram://<bot_token>/<chat_id>
#   Pushover:  pover://<user_key>@<app_token>
#   Discord:   discord://<webhook_id>/<webhook_token>
#   Slack:     slack://<TokenA>/<TokenB>/<TokenC>/<channel>
#   ntfy:      ntfy://<long-random-topic>      (the topic IS the secret — make it unguessable)
# Separate multiple targets with spaces. Prefer a PRIVATE service (Telegram/Pushover/Discord),
# since alerts contain private-repo names.
APPRISE_URL=tgram://xxxxxxxxxx/xxxxxxxxxx

# ----- Fallback: SMTP email (used only if APPRISE_URL is blank) -----
# NOTE: imazen.io's Workspace blocks app passwords, so this path won't work for lilith@imazen.io.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=app-password
# ALERT_TO=lilith@imazen.io
# ALERT_FROM=imazen org-watch <you@example.com>

# ---- optional overrides (defaults are fine) ----
# WATCH_SELF_LOGINS=lilith                 # comma-sep logins treated as "the owner"
# WATCH_BOT_DENYLIST=some-extra-bot        # extra bots to ignore (on top of built-ins)
# WATCH_STATE_REPO=imazen/org-watch        # repo holding the WATCH_STATE variable
